FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY apps/api/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY apps/api/ ./

# The scoring agent's holistic LLM rubric lives in repo-root docs/, outside
# apps/api. Without it, rubric_available() is False and scoring silently falls
# back to deterministic heuristics. Copy it in and point the loader at it.
COPY docs/scoring_agent_md ./docs/scoring_agent_md
ENV SCORING_RUBRIC_DIR=/app/docs/scoring_agent_md

RUN useradd -m -u 1001 appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD curl -f "http://localhost:${PORT:-8000}/health" || exit 1

CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000} --workers 2"]
