# ── ADIP Production Environment ──────────────────────────────────────────────
# Copy to .env.prod (gitignored) and fill in real values before running:
#   docker compose --profile prod up --build
#
# ⚠️  SECURITY: The git history of this repo contains historically-committed
# API keys. Rotate ALL credentials below before deploying to production:
#   - ANTHROPIC_API_KEY
#   - GROQ_API_KEY / GROQ_API_KEY_BACKUP
#   - WHATSAPP_ACCESS_TOKEN
#   - WHATSAPP_APP_SECRET
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase) ── REQUIRED ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Web app (Vite build-time vars) ── REQUIRED ───────────────────────────────
# These are baked into the browser bundle — do NOT put secrets here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_AGENT_API_URL=https://your-domain.com

# ── LLM providers ── REQUIRED ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

GROQ_API_KEY=gsk-your-key-here
GROQ_API_KEY_BACKUP=gsk-your-second-key-here

# OPTIONAL — tertiary LLM fallback (NVIDIA NIM)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# ── WhatsApp Business Cloud API (Meta) ── REQUIRED if using WhatsApp ─────────
WHATSAPP_PROVIDER=meta
WHATSAPP_PHONE_NUMBER_ID=your-19-digit-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-system-user-token
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_WEBHOOK_VERIFY_TOKEN=choose-a-random-string

# ── File uploads ── REQUIRED for call recordings in prod ─────────────────────
# Create a bucket named 'call-recordings' in your Supabase Storage dashboard
SUPABASE_STORAGE_BUCKET=call-recordings

# ── Event bus (optional — safe defaults shown) ───────────────────────────────
EVENT_BUS_ENABLED=1
EVENT_MAX_RETRIES=3
EVENT_RETRY_BACKOFF_MS=500

# ── Scoring ── OPTIONAL ───────────────────────────────────────────────────────
# Set to 1 only on a paid Groq tier with high TPM (avoids 413 on free tier)
SCORING_RUBRIC_FULL=0

# ── Observability ── OPTIONAL ─────────────────────────────────────────────────
LOG_LEVEL=INFO
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
