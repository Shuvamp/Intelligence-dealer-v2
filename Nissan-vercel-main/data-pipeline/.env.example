# Copy to .env and set your local Postgres creds, then: set -a && . ./.env && set +a
#
# Default target is the LOCAL SUPABASE Postgres (port 54322, db "postgres"),
# so the pipeline schemas (bronze/silver/gold/agent) live alongside the spine
# (public.*) in one DB. The bridge loader (data-pipeline/bridge/) writes
# directly to public.* using these same creds — `postgres` is the DB
# superuser locally, which has BYPASSRLS (the audited system-ingestion path).
#
# To run the prototype against a standalone Postgres instead, switch
# PGPORT=5432 and PGDATABASE=adip_pipeline (the bridge will not work there
# because there's no public.* to write into).
PGHOST=localhost
PGPORT=54322
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=postgres
PGSSLMODE=prefer
# run_demo.sh / run_local.sh set DBT_PROFILES_DIR automatically (absolute path)
