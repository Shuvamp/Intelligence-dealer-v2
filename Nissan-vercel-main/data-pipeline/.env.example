# Copy to .env and set your hosted Supabase Postgres creds, then: set -a && . ./.env && set +a
#
# Default target is the HOSTED SUPABASE Postgres (Project Settings -> Database
# -> Connection string), so the pipeline schemas (bronze/silver/gold/agent)
# live alongside the spine (public.*) in one DB. The bridge loader
# (data-pipeline/bridge/) writes directly to public.* using these same
# creds — `postgres` is the DB superuser, which has BYPASSRLS (the audited
# system-ingestion path).
#
# To run the prototype against a standalone Postgres instead, point at that
# instance and set PGDATABASE=adip_pipeline (the bridge will not work there
# because there's no public.* to write into).
PGHOST=db.your-project.supabase.co
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your-db-password
PGDATABASE=postgres
PGSSLMODE=require
# run_demo.sh / run_local.sh set DBT_PROFILES_DIR automatically (absolute path)
